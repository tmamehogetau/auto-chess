{
  "name": "auto-chess-mvp",
  "version": "1.0.0",
  "description": "Auto-Chess MVP with Colyseus",
  "main": "server.mjs",
  "private": true,
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:client": "vitest run tests/client",
    "test:client:ci": "cross-env SUPPRESS_VERBOSE_TEST_LOGS=true vitest run tests/client --reporter=dot --silent=passed-only",
    "test:server": "vitest run tests/server",
    "test:server:audit": "node scripts/server-test-manifest.mjs --audit",
    "test:server:parallel-safe": "cross-env SUPPRESS_VERBOSE_TEST_LOGS=true node scripts/server-test-manifest.mjs --run=parallel-safe -- --reporter=dot --silent=passed-only",
    "test:server:serial-required": "cross-env SUPPRESS_VERBOSE_TEST_LOGS=true node scripts/server-test-manifest.mjs --run=serial-required -- --maxWorkers=1 --reporter=dot --silent=passed-only",
    "test:server:ci": "run-s --silent test:server:audit test:server:parallel-safe test:server:serial-required",
    "test:integration": "vitest run tests/server/boss-exclusive-shop.integration.test.ts tests/server/feature-flag.integration.test.ts tests/server/full-game-simulation.integration.test.ts tests/server/game-room.feature-flag.integration.test.ts tests/server/game-room.integration.test.ts tests/server/hero-system.integration.test.ts tests/server/prep-duration-45s.integration.test.ts tests/server/rumor-influence.integration.test.ts tests/server/shared-board-room.integration.test.ts tests/server/shared-pool.integration.test.ts tests/server/spell-card.integration.test.ts tests/server/sub-unit-system.integration.test.ts",
    "test:e2e": "vitest run tests/e2e --maxWorkers=1",
    "test:e2e:audit": "node scripts/e2e-test-manifest.mjs --audit",
    "test:e2e:ci:a": "cross-env SUPPRESS_VERBOSE_TEST_LOGS=true node scripts/e2e-test-manifest.mjs --run=a -- --maxWorkers=1 --reporter=dot --silent=passed-only",
    "test:e2e:ci:b": "cross-env SUPPRESS_VERBOSE_TEST_LOGS=true node scripts/e2e-test-manifest.mjs --run=b -- --maxWorkers=1 --reporter=dot --silent=passed-only",
    "test:e2e:ci": "run-s --silent test:e2e:audit test:e2e:ci:a test:e2e:ci:b",
    "test:balance": "vitest run tests/server/combat/boss-raid-simulation.test.ts",
    "test:all-flags": "npm run test:run && cross-env FEATURE_ENABLE_HERO_SYSTEM=true FEATURE_ENABLE_SHARED_POOL=true FEATURE_ENABLE_PHASE_EXPANSION=true npm run test:run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:watch": "vitest --coverage",
    "prepare": "lefthook install",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "tsc --noEmit --pretty false",
    "verify:ci": "node scripts/run-verify-ci.mjs",
    "verify:quick": "run-s --silent typecheck test:client:ci test:server:parallel-safe",
    "verify:full": "npm run verify:ci && npm run test:coverage",
    "client:check": "node scripts/serve-client-check.mjs",
    "server": "tsx server.ts",
    "play": "npm-run-all --parallel server client:check",
    "w6:kpi-report": "node scripts/w6-kpi-report.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@colyseus/testing": "^0.17.11",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^10.1.0",
    "lefthook": "^2.1.4",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.14",
    "@colyseus/sdk": "^0.17.34",
    "colyseus": "^0.17.8"
  }
}
